@model Blog.Web.Models.ViewModels.LoginViewModel


@{
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow p-4" style="width: 400px;">
            
        <h3 class="text-center mb-4">Login</h3>

        <form method="post">

            <!-- Username -->
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" class="form-control" placeholder="Enter username" required asp-for="Username">
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" placeholder="Enter password" required asp-for="Password">
            </div>

            <!-- Button -->
            <button type="submit" class="btn btn-primary w-100">
                Login
            </button>

        </form>

    </div>
</div>
