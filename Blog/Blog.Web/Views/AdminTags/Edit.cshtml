@model Blog.Web.Models.ViewModels.EditTagRequest
@{
}
<div class="container py-5">

    @if(Model!=null)
    {
        <form method="post">
            <div class="container-fluid">
                <h1>Edit the Tags</h1>
            </div>

            <div class="mb-3">
                <label class="form-label">Id</label>
                <input type="text" class="form-control" id="Id" asp-for="Id" readonly>
            </div>
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" id="name" asp-for="Name">
            </div>
            <div class="mb-3">
                <label class="form-label">Display Name</label>
                <input type="text" class="form-control" id="displayName" asp-for="DisplayName">
            </div>
            <div class="mb-3">
                <div class="d-flex">
                    <button type="submit" class="btn btn-primary">Updated</button>
                    <button class="btn btn-danger ms-2" type="submit" asp-area="" asp-action="Delete" asp-controller="AdminTags">Delete</button>

                </div>
            
            </div>
        </form>
    }
    else
    {
        <p>No found any Tags</p>
    }

    
</div>

